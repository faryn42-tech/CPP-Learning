#include<iostream>
using namespace std;
int main()
{
	int x;
	cin >> x;
	bool a = x % 2 == 0;
	bool b = x > 4 && x <= 12;
	if (a && b)
	{
		cout << "1" << " " << "1" << " " << "0" << " " << "0" << endl;
	}
	else if (a || b)
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else if (a ^ b)
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else
	{
		cout << "0" << " " << "0" << " " << "0" << " " << "1" << endl;
	}
	return 0;
}
