#include<iostream>
using namespace std;
int main()
{
	int n;
	int a = 1;
	cin >> n;
	//确定行数
	for (int i = 1; i <= n; i++)
	{
		//确定每行的数字个数
		for (int j = 1; j <= n + 1 - i; j++)
		{
			if (a < 10)
			{
				cout << 0 << a;
			}
			else
			{
				cout << a;
			}
			//每循环一次a就+1
			a++;
		}
		cout << endl;
	}
	return 0;
}
