#include<iostream>
using namespace std;
int main()
{
	double m, h, MBI;
	cin >> m >> h;
	MBI = m /( h * h);
	if (MBI < 18.5)
	{
		cout << "Underweight" << endl;
	}
	else if (MBI >= 18.5 && MBI < 24)
	{
		cout << "Normal" << endl;
	}
	else if (MBI > 24)
	{
		cout << MBI << endl;
		cout << "Overweight" << endl;
	}
	return 0; 
}
