#include<iostream>
using namespace std;
int main()
{
	int x;
	cin >> x;
	if (x % 2 == 0 && x > 4 && x <= 12)
	{
		cout << "1" << " " << "1" << " " << "0" << " " << "0" << endl;
	}
	else if (x % 2 == 0 && !(x > 4 && x <= 12))
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else if (!(x % 2 == 0) && x > 4 && x <= 12)
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else
	{
		cout << "0" << " " << "0" << " " << "0" << " " << "1" << endl;
	}
	return 0;
}
