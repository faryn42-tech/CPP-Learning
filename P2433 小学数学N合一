#include<iostream>
#include<cmath>
#include<iomanip>
using namespace std;
int main()
{
    int T;
    cin >> T;
    if (T == 1)
    {
        cout << "I love Luogu!";
    }
    else if (T == 2)
    {
        cout << 2 + 4 << " " << 10 - 2 - 4;
    }
    else if (T == 3)
    {
        int a;
        a = floor(14 / 4);
        cout << a << endl;
        cout << a * 4 << endl;
        cout << 14 - (a * 4) << endl;
    }
    else if (T == 4)
    {
        double b;
        b = 1.0 * 500 / 3;
        cout << setprecision(6) << b;
    }
    else if (T == 5)
    {
        int s, t;
        s = 260 + 220;
        t = s / (12 + 20);
        cout << t;
    }
    else if (T == 6)
    {
        cout << hypot(9, 6);//<cmath>里的求直角斜边
    }
    else if (T == 7)
    {
        int c, d, e;
        c = 100 + 10;
        d = c - 20;
        cout << c << endl;
        cout << d << endl;
        cout << 0 << endl;
    }
    else if (T == 8)
    {
        cout << 2 * 5 * 3.141593 << endl;
        cout << 3.141593 * pow(5, 2) << endl;
        cout << (1.0 * 4 / 3) * 3.141593 * pow(5, 3) << endl;
    }
    else if (T == 9)
    {
        int day1, day2, day3, day4;
        day4 = 1;
        day3 = (day4 + 1) * 2;
        day2 = (day3 + 1) * 2;
        day1 = (day2 + 1) * 2;
        cout << day1;
    }
    else if (T == 10)
    {
        int initial, diff1, diff2;
        int n;//n台机器能够做到10分钟评测完毕
        double increaseV;
        //这里是8台机器比10台机器多处理的程序量
        diff1 = (8 * 30) - (10 * 6);
        //这里是8台机器比10台机器多花的时间
        diff2 = 30 - 6;
        increaseV = 1.0*diff1 / diff2;
        //啊！自定义机器的单位速度为1吧，反正不影响结果，毕竟其他变量都会随之成倍增长
        //那么原有的程序就是机器处理的总量减去增长的量
        initial = (60 * 1) - (6 * increaseV);
        n = (10 * increaseV + initial) / 10;
        cout << n;
    }
    else if (T == 11)
    {
        cout << 1.0 * 100 / (8 - 5);
    }
    else if (T == 12)
    {
        cout << int('M' - 64) << endl;
        cout << char(64 + 18) << endl;
    }
    else if (T == 13)
    {
        double v1, v2, v3;
        //记得把4/3变成浮点数
        v1 = (1.0*4 / 3) * 3.141593 * 4 * 4 * 4;
        v2 = (1.0 * 4 / 3) * 3.141593 * 10 * 10 * 10;
        v3 = v1 + v2;
        cout << int(cbrt(v3));
    }
    else if (T == 14)
    {
        int a1, a2, t1, t2;
        int p1 = 110;
        int p2 = 110;
        //10个人，加价1元少一个，最多少10个
        for (int i = 1; i <= 10; i++)
        {
            a1 = 10 - i;
            t1 = (110 + i) * a1;
            if (t1 >= 0 && t1 == 3500)
            {
                p1 = 110 + i;
            }
        }
        //从110元降价，最多降价110元
        for (int j = 1; j <= 110; j++)
        {
            a2 = 10 + j;
            t2 = (110 - j) * a2;
            if (t2 >= 0 && t2 == 3500)
            {
                p2 = 110 - j;
            }
        }
        cout << min(p1, p2);
    }
    return 0;
}
