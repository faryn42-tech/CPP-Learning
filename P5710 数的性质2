#include<iostream>
using namespace std;
int main()
{
	int x;
	cin >> x;
	bool a = x % 2 == 0;
	bool b = x > 4 && x <= 12;
	if (a == 1 && b == 1)
	{
		cout << "1" << " " << "1" << " " << "0" << " " << "0" << endl;
	}
	else if (a == 1 && b == 0)
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else if (a == 0 && b == 1)
	{
		cout << "0" << " " << "1" << " " << "1" << " " << "0" << endl;
	}
	else if (a == 0 && b == 0)
	{
		cout << "0" << " " << "0" << " " << "0" << " " << "1" << endl;
	}
	return 0;
}
